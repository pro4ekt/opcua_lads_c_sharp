<?xml version="1.0" encoding="utf-8"?>
<UANodeSet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
           xmlns="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd">
    
    <NamespaceUris>
        <Uri>http://lab.server/Pipette/</Uri>
    </NamespaceUris>

    <Aliases>
        <Alias Alias="Boolean">i=1</Alias>
        <Alias Alias="UInt16">i=5</Alias>
        <Alias Alias="Double">i=11</Alias>
        <Alias Alias="String">i=12</Alias>
        <Alias Alias="Organizes">i=35</Alias>
        <Alias Alias="HasTypeDefinition">i=40</Alias>
        <Alias Alias="HasComponent">i=47</Alias>
        <Alias Alias="FolderType">i=61</Alias>
        <Alias Alias="BaseDataVariableType">i=63</Alias>
    </Aliases>

    <!-- 1. Корневой объект: Pipette -->
    <UAObject NodeId="ns=1;s=Pipette" BrowseName="1:Pipette">
        <DisplayName>Pipette</DisplayName>
        <References>
            <Reference ReferenceType="Organizes" IsForward="false">i=85</Reference> <!-- ObjectsFolder -->
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>

            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_BatteryComponent</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_Functions</Reference>
        </References>
    </UAObject>

    <!-- Переменные для Device -->
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_DeviceId" BrowseName="1:DeviceId" DataType="String" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>DeviceId</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:String>PIP-001</uax:String>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_Model" BrowseName="1:Model" DataType="String" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>Model</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:String>LADS-Pipette-V1</uax:String>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_MinVolume" BrowseName="1:MinVolume" DataType="Double" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>MinVolume</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Double>0.5</uax:Double>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_MaxVolume" BrowseName="1:MaxVolume" DataType="Double" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>MaxVolume</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Double>10.0</uax:Double>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_CurrentVolume" BrowseName="1:CurrentVolume" DataType="Double" AccessLevel="3" UserAccessLevel="3">
        <DisplayName>CurrentVolume</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Double>5000.0</uax:Double>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_DeviceComponent_TipPresent" BrowseName="1:TipPresent" DataType="Boolean" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>TipPresent</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Boolean>false</uax:Boolean>
        </Value>
    </UAVariable>

    <!-- 2. Дочерний объект: DeviceComponent -->
    <UAObject NodeId="ns=1;s=Pipette_DeviceComponent" BrowseName="1:DeviceComponent">
        <DisplayName>DeviceComponent</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_DeviceId</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_Model</Reference>
            
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_MinVolume</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_MaxVolume</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_CurrentVolume</Reference>
            
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_DeviceComponent_TipPresent</Reference>
        </References>
    </UAObject>
    
    <!-- Переменные для Battery -->
    <UAVariable NodeId="ns=1;s=Pipette_BatteryComponent_BatteryLevel" BrowseName="1:BatteryLevel" DataType="UInt16" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>BatteryLevel</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_BatteryComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:UInt16>100</uax:UInt16>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=Pipette_BatteryComponent_Charging" BrowseName="1:Charging" DataType="Boolean" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>Charging</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_BatteryComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Boolean>false</uax:Boolean>
        </Value>
    </UAVariable>

    <!-- 3. Дочерний объект: BatteryComponent -->
    <UAObject NodeId="ns=1;s=Pipette_BatteryComponent" BrowseName="1:BatteryComponent">
        <DisplayName>BatteryComponent</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_BatteryComponent_BatteryLevel</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_BatteryComponent_Charging</Reference>
        </References>
    </UAObject>
    
    <!-- Переменные для Functions -->
    <UAVariable NodeId="ns=1;s=Pipette_Functions_Speed" BrowseName="1:Speed" DataType="UInt16" AccessLevel="3" UserAccessLevel="3">
        <DisplayName>Speed</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_Functions</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:UInt16>50</uax:UInt16>
        </Value>
    </UAVariable>
    
    <!-- Методы RPC (Executable="true") -->
    <UAMethod NodeId="ns=1;s=Pipette_Functions_StartPipetting" BrowseName="1:StartPipetting">
        <DisplayName>StartPipetting</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_Functions</Reference>
        </References>
    </UAMethod>
    <UAMethod NodeId="ns=1;s=Pipette_Functions_AbortPipetting" BrowseName="1:AbortPipetting">
        <DisplayName>AbortPipetting</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette_Functions</Reference>
        </References>
    </UAMethod>

    <!-- 4. Дочерний объект: Functions -->
    <UAObject NodeId="ns=1;s=Pipette_Functions" BrowseName="1:Functions">
        <DisplayName>Functions</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=Pipette</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_Functions_Speed</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_Functions_StartPipetting</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=Pipette_Functions_AbortPipetting</Reference>
        </References>
    </UAObject>
</UANodeSet>
