<?xml version="1.0" encoding="utf-8"?>
<UANodeSet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
           xmlns="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd">

    <NamespaceUris>
        <Uri>http://lab.server/RobotArm/</Uri>
    </NamespaceUris>

    <Aliases>
        <Alias Alias="Boolean">i=1</Alias>
        <Alias Alias="UInt16">i=5</Alias>
        <Alias Alias="Double">i=11</Alias>
        <Alias Alias="String">i=12</Alias>
        <Alias Alias="Organizes">i=35</Alias>
        <Alias Alias="HasTypeDefinition">i=40</Alias>
        <Alias Alias="HasComponent">i=47</Alias>
        <Alias Alias="FolderType">i=61</Alias>
        <Alias Alias="BaseDataVariableType">i=63</Alias>
    </Aliases>

    <!-- 1. Корневой объект: RobotArm -->
    <UAObject NodeId="ns=1;s=RobotArm" BrowseName="1:RobotArm">
        <DisplayName>RobotArm</DisplayName>
        <References>
            <Reference ReferenceType="Organizes" IsForward="false">i=85</Reference> <!-- ObjectsFolder -->
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>

            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_DeviceComponent</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_BatteryComponent</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_Functions</Reference>
        </References>
    </UAObject>

    <!-- Переменные для Device -->
    <UAVariable NodeId="ns=1;s=RobotArm_DeviceComponent_DeviceId" BrowseName="1:DeviceId" DataType="String" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>DeviceId</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:String>ROB-001</uax:String>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=RobotArm_DeviceComponent_Model" BrowseName="1:Model" DataType="String" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>Model</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_DeviceComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:String>LADS-RobotArm-V1</uax:String>
        </Value>
    </UAVariable>

    <!-- 2. Дочерний объект: DeviceComponent -->
    <UAObject NodeId="ns=1;s=RobotArm_DeviceComponent" BrowseName="1:DeviceComponent">
        <DisplayName>DeviceComponent</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_DeviceComponent_DeviceId</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_DeviceComponent_Model</Reference>
        </References>
    </UAObject>

    <!-- Переменные для Battery -->
    <UAVariable NodeId="ns=1;s=RobotArm_BatteryComponent_BatteryLevel" BrowseName="1:BatteryLevel" DataType="UInt16" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>BatteryLevel</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_BatteryComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:UInt16>100</uax:UInt16>
        </Value>
    </UAVariable>
    <UAVariable NodeId="ns=1;s=RobotArm_BatteryComponent_Charging" BrowseName="1:Charging" DataType="Boolean" AccessLevel="1" UserAccessLevel="1">
        <DisplayName>Charging</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_BatteryComponent</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Boolean>false</uax:Boolean>
        </Value>
    </UAVariable>

    <!-- 3. Дочерний объект: BatteryComponent -->
    <UAObject NodeId="ns=1;s=RobotArm_BatteryComponent" BrowseName="1:BatteryComponent">
        <DisplayName>BatteryComponent</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_BatteryComponent_BatteryLevel</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_BatteryComponent_Charging</Reference>
        </References>
    </UAObject>

    <!-- Переменные для Functions -->
    <UAVariable NodeId="ns=1;s=RobotArm_Functions_MoveSpeed" BrowseName="1:MoveSpeed" DataType="Double" AccessLevel="3" UserAccessLevel="3">
        <DisplayName>MoveSpeed</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_Functions</Reference>
            <Reference ReferenceType="HasTypeDefinition">BaseDataVariableType</Reference>
        </References>
        <Value>
            <uax:Double>1.5</uax:Double>
        </Value>
    </UAVariable>

    <!-- Методы RPC (Executable="true") -->
    <UAMethod NodeId="ns=1;s=RobotArm_Functions_Grab" BrowseName="1:Grab">
        <DisplayName>Grab</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_Functions</Reference>
        </References>
    </UAMethod>
    <UAMethod NodeId="ns=1;s=RobotArm_Functions_Move" BrowseName="1:Move">
        <DisplayName>Move</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_Functions</Reference>
        </References>
    </UAMethod>
    <UAMethod NodeId="ns=1;s=RobotArm_Functions_Release" BrowseName="1:Release">
        <DisplayName>Release</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm_Functions</Reference>
        </References>
    </UAMethod>

    <!-- 4. Дочерний объект: Functions -->
    <UAObject NodeId="ns=1;s=RobotArm_Functions" BrowseName="1:Functions">
        <DisplayName>Functions</DisplayName>
        <References>
            <Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=RobotArm</Reference>
            <Reference ReferenceType="HasTypeDefinition">FolderType</Reference>
            
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_Functions_MoveSpeed</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_Functions_Grab</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_Functions_Move</Reference>
            <Reference ReferenceType="HasComponent">ns=1;s=RobotArm_Functions_Release</Reference>
        </References>
    </UAObject>
</UANodeSet>
